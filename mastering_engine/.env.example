# ─── Stemy Mastering Engine — environment variables ───────────────────────
# Copy to .env and edit before running.

# Server port (default: 5050)
PORT=5050

# Set to "development" to enable Flask debug mode + auto-reload
FLASK_ENV=production

# Allowed CORS origins (comma-separated). "*" = allow all.
# Example: ALLOWED_ORIGINS=https://stemy.io,https://app.stemy.io
ALLOWED_ORIGINS=*

# Max upload size in bytes (default 100 MB). No duration limit.
# STEMY_MAX_UPLOAD_BYTES=104857600

# VPS turbo (default on): ffmpeg single-pass, target ≤90s, FLAC output
# STEMY_TURBO=1
# STEMY_TEMP_DIR=/var/lib/stemy/masters
# STEMY_TURBO_WORKERS=6
# STEMY_TARGET_SEC=90
# STEMY_OUTPUT_EXT=.flac
# STEMY_FFMPEG_TIMEOUT_SEC=0           # 0 = auto from duration
# STEMY_FFMPEG_MAX_DURATION_SEC=600    # above 10 min → parallel workers (not ffmpeg loudnorm)
# STEMY_PARALLEL_MAX_DURATION_SEC=7200 # hard cap (~2 h)
# STEMY_FLAC_COMPRESSION=1             # 1 = fast encode; 5 = smaller/slower
# STEMY_ALLOW_LOCAL_PATH=1
# FFMPEG_PATH=/usr/bin/ffmpeg
